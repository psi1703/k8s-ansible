# Copy to .env, edit once, then run:
#   ./setup.sh
#
# DEVtoPROD test architecture:
#   - This server/real host is the K3s control-plane and Ansible runner.
#   - The provisioner creates only two DEVtoPROD worker VMs.
#   - NFS is external and is not joined to Kubernetes.
#   - frontend/app.jsx is source; frontend/app.js is generated during deployment.
#
# Do not commit populated .env files.

REPO_URL="https://github.com/psi1703/k8s-ansible.git"
REPO_REF="k8s-ansible-DEVtoPROD"
INSTALL_DIR="/opt/k8s-ansible-DEVtoPROD"
NAMESPACE="otp-relay-devprod"

APP_IMAGE="otp-relay:latest"
MONITOR_IMAGE="otp-monitor:latest"
DEPLOY_MODE="full"

# Service / Ingress
# ClusterIP + Ingress is the preferred default for Traefik.
# TLS_HOST is the Ingress hostname and, when TLS is enabled, the certificate hostname.
# TLS_ENABLED=1 means HTTPS ingress.
# TLS_SELF_SIGNED=1 lets the installer create the TLS secret if it is missing.
# Existing self-signed TLS secrets are kept by default.
# Set TLS_ROTATE_SELF_SIGNED=1 only when you intentionally want a new cert.
SERVICE_TYPE="ClusterIP"
SERVICE_NODE_PORT="30080"
LOADBALANCER_IP=""
INGRESS_ENABLED="1"
TLS_ENABLED="1"
TLS_HOST="srvotptest-devprod.init-db.lan"
TLS_SECRET_NAME="otp-relay-devprod-tls"
TLS_SELF_SIGNED="1"
TLS_ROTATE_SELF_SIGNED="0"
PORTAL_URL="https://srvotptest-devprod.init-db.lan"

# App storage
# NFS is external. Set NFS_SERVER and NFS_PATH to the real export.
PVC_STORAGE_CLASS="otp-relay-devprod-nfs"
PVC_SIZE="1Gi"
NFS_ENABLED="1"
NFS_SERVER="nfsdevprod.init-db.lan"
NFS_PATH="/srv/nfs/otp-relay-devprod"
NFS_STORAGE_CLASS="otp-relay-devprod-nfs"
NFS_PV_NAME="otp-relay-data-devprod-nfs-pv"
NFS_MOUNT_OPTIONS="nfsvers=4.1"

# Replicas / scheduling
# App and Redis should run on worker nodes through node labels.
# Monitor can run on the control-plane/server because it needs host network/ARP access.
REPLICA_COUNT="2"
APP_NODE_SELECTOR_KEY="otp-relay/app-node"
APP_NODE_SELECTOR_VALUE="true"
MONITOR_NODE_SELECTOR_KEY="otp-relay/monitor-node"
MONITOR_NODE_SELECTOR_VALUE="true"
REDIS_NODE_SELECTOR_KEY="otp-relay/redis-node"
REDIS_NODE_SELECTOR_VALUE="true"

# MetalLB
# DEVtoPROD intentionally keeps MetalLB enabled.
# Keep this range separate from worker VM IPs.
REQUIRE_METALLB="1"
INSTALL_METALLB="1"
METALLB_VERSION="v0.15.3"
METALLB_IP_RANGE="172.31.11.240-172.31.11.250"
METALLB_POOL_NAME="otp-relay-devprod-pool"

# Monitor / phone presence
# DEVtoPROD test can use a VM to fake phone presence.
PHONE_IP="172.31.11.123"
PHONE_INTERFACE="br0"
PHONE_PING_INTERVAL="10"
PHONE_OFFLINE_THRESHOLD="30"
PHONE_ARP_COUNT="2"
PHONE_ARP_TIMEOUT="2"
MONITOR_METRICS_PORT="9101"

# Runtime paths
OTP_RELAY_DATA_DIR="/app/data"
USERS_EXCEL_PATH="/app/data/users.xlsx"
AUDIT_LOG_PATH="/app/data/audit.log"
CLAIM_EXPIRY_SEC="90"
OTP_DISPLAY_SEC="285"
CONCURRENT_RISK_SEC="30"

# Secrets
# Leave SMS_SECRET_TOKEN empty to let setup generate one, or set a strong value manually.
SMS_SECRET_TOKEN=""
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Redis HA/shared state
REDIS_ENABLED="1"
REDIS_URL="redis://otp-redis-haproxy:6379/0"
REDIS_REQUIRED="1"
REDIS_STORAGE_CLASS="local-path"
REDIS_SIZE="1Gi"
REDIS_SPREAD_RECREATE_PVCS="auto"

# Installer behavior
# GitHub Actions syncs this branch into INSTALL_DIR.
# Do not let the installer clean or resync from main.
RUNTIME_DATA_DIR=""
SKIP_HELP_DOCS_BUILD="0"
GIT_CLEAN="0"
SKIP_REPO_SYNC="1"
NONINTERACTIVE="1"
INSTALL_GITHUB_RUNNER=""
GITHUB_RUNNER_URL=""
GITHUB_RUNNER_TOKEN=""
GITHUB_RUNNER_DIR="/opt/actions-runner"
GITHUB_RUNNER_USER="actions-runner"
RUNNER_ONLY="0"
DOCKER_BIN=""
DISTRIBUTE_IMAGES_TO_NODES="1"
IMAGE_DISTRIBUTION_PORT="18080"
IMAGE_IMPORTER_IMAGE="redis:7-alpine"

# Worker VM provisioner inputs
# No CP_IP exists in this design. The server is the control-plane.
# VM_PASSWORD is required when provisioning/repairing worker VMs.
# DEVtoPROD uses separate worker names and IPs to avoid collision with the other branch.
BRIDGE_NAME="br0"
HOST_IFACE="br0"
HOST_IP_CIDR="172.31.11.111/24"
GATEWAY="172.31.11.1"
DNS="172.31.11.1"
PREFIX="24"
IP_SCAN_PREFIX="172.31.11"
IP_SCAN_START="160"
IP_SCAN_END="169"
AUTO_ASSIGN_IPS="0"
WORKER1_IP="172.31.11.160"
WORKER2_IP="172.31.11.161"
VM_USER="otp-relay"
VM_PASSWORD="CHANGE_ME_VM_PASSWORD"
VM_RAM_MB="3072"
VM_VCPUS="2"
VM_DISK_GB="20"
WORKER1_NAME="otp-devprod-worker1"
WORKER2_NAME="otp-devprod-worker2"

# Observability
# Keep this namespace separate from the old branch if both share one control-plane cluster.
OBSERVABILITY_NAMESPACE="observability-devprod"
OBSERVABILITY_INSTALL_STACK="1"
OBSERVABILITY_STACK_CHART_VERSION="85.0.1"
GRAFANA_HOST="grafana-devprod.init-db.lan"
