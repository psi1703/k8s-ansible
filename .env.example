# OTP Relay Kubernetes release bundle configuration example.
#
# Copy to .env and edit for the dev/build host:
#
#   cp .env.example .env
#
# Bundle-only contract:
# - This repo builds a sealed production release bundle only.
# - It does not deploy to Kubernetes.
# - It does not install K3s.
# - It does not run kubectl apply.
# - It does not run Helm install/upgrade.
# - It does not import images into a live cluster.
# - It does not restart deployments.
# - It does not install GitHub Actions runners.
# - It does not provision worker VMs.
# - It does not validate a live cluster.
#
# The production server receives only the finished bundle.

# ---------------------------------------------------------------------------
# Repository / build source
# ---------------------------------------------------------------------------

REPO_URL=""
REPO_REF="k8s-ansible-DEVtoPROD"
INSTALL_DIR="/opt/k8s-ansible-DEVtoPROD"

# ---------------------------------------------------------------------------
# Bundle-only safety flags
# ---------------------------------------------------------------------------

RELEASE_MODE="bundle"

SKIP_CLUSTER_DEPLOY="1"
SKIP_K3S_INSTALL="1"
SKIP_HELM_INSTALL="1"
SKIP_KUBECTL_APPLY="1"
SKIP_IMAGE_IMPORT="1"
SKIP_ROLLOUT_RESTART="1"
SKIP_LIVE_CLUSTER_VALIDATE="1"
SKIP_GITHUB_RUNNER_INSTALL="1"
SKIP_VM_PROVISIONING="1"

DEPLOY_OTP_RELAY="0"
VALIDATE_OTP_RELAY="0"
INSTALL_GITHUB_RUNNER="0"
RUNNER_ONLY="0"
DISTRIBUTE_IMAGES_TO_NODES="0"

# ---------------------------------------------------------------------------
# Artifact selector
# ---------------------------------------------------------------------------
#
# Historical name retained for compatibility:
# DEPLOY_MODE now means "which artifacts to build/package", not "deploy".
#
# Supported:
#   full    - app image archive + monitor image archive + rendered manifests
#   app     - app image archive + rendered app manifests
#   monitor - monitor image archive + rendered monitor manifests
#   none    - metadata/environment validation only

DEPLOY_MODE="full"

# ---------------------------------------------------------------------------
# Images to render/export
# ---------------------------------------------------------------------------

APP_IMAGE="otp-relay:latest"
MONITOR_IMAGE="otp-monitor:latest"
DOCKER_BIN=""

# ---------------------------------------------------------------------------
# Kubernetes namespace rendered into manifests
# ---------------------------------------------------------------------------

NAMESPACE="otp-relay-devprod"

# ---------------------------------------------------------------------------
# Service / ingress values rendered into manifests
# ---------------------------------------------------------------------------

SERVICE_TYPE="ClusterIP"
SERVICE_NODE_PORT="30080"
LOADBALANCER_IP=""

INGRESS_ENABLED="1"
TLS_ENABLED="0"
TLS_HOST="CHANGE_ME_TLS_HOST"
TLS_SECRET_NAME="otp-relay-tls"
TLS_SELF_SIGNED="1"

# Leave empty to auto-derive from TLS_HOST or SERVER_IP at build time.
PORTAL_URL=""

# ---------------------------------------------------------------------------
# Storage values rendered into manifests
# ---------------------------------------------------------------------------

PVC_STORAGE_CLASS="otp-relay-devprod-nfs"
PVC_SIZE="1Gi"

NFS_ENABLED="1"
NFS_SERVER=""
NFS_PATH=""
NFS_STORAGE_CLASS="otp-relay-devprod-nfs"
NFS_PV_NAME="otp-relay-data-devprod-nfs-pv"
NFS_MOUNT_OPTIONS="nfsvers=4.1"

# ---------------------------------------------------------------------------
# Replica / placement values rendered into manifests
# ---------------------------------------------------------------------------

REPLICA_COUNT="2"

APP_NODE_SELECTOR_KEY="otp-relay/app-node"
APP_NODE_SELECTOR_VALUE="true"

MONITOR_NODE_SELECTOR_KEY="otp-relay/monitor-node"
MONITOR_NODE_SELECTOR_VALUE="true"

REDIS_NODE_SELECTOR_KEY="otp-relay/redis-node"
REDIS_NODE_SELECTOR_VALUE="true"

# ---------------------------------------------------------------------------
# MetalLB intent recorded in bundle metadata only
# ---------------------------------------------------------------------------
#
# The bundle builder does not install MetalLB.
# Production-side LoadBalancer setup belongs to the approved production procedure.

REQUIRE_METALLB="0"
INSTALL_METALLB="0"
METALLB_VERSION="v0.15.3"
METALLB_IP_RANGE=""
METALLB_POOL_NAME="otp-relay-pool"

# ---------------------------------------------------------------------------
# Runtime app / monitor values rendered into ConfigMap/manifests
# ---------------------------------------------------------------------------

PHONE_IP=""
PHONE_INTERFACE=""
PHONE_PING_INTERVAL="10"
PHONE_OFFLINE_THRESHOLD="30"
PHONE_ARP_COUNT="2"
PHONE_ARP_TIMEOUT="2"
MONITOR_METRICS_PORT="9101"

OTP_RELAY_DATA_DIR="/app/data"
USERS_EXCEL_PATH="/app/data/users.xlsx"
AUDIT_LOG_PATH="/app/data/audit.log"

CLAIM_EXPIRY_SEC="90"
OTP_DISPLAY_SEC="285"
CONCURRENT_RISK_SEC="30"

# ---------------------------------------------------------------------------
# Secrets
# ---------------------------------------------------------------------------
#
# Do not commit populated .env files.
# The bundle builder does not create Kubernetes secrets.
# Production-side secret creation belongs to the approved production procedure.

SMS_SECRET_TOKEN=""
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# ---------------------------------------------------------------------------
# Redis values rendered into manifests
# ---------------------------------------------------------------------------

REDIS_ENABLED="1"
REDIS_URL="redis://otp-redis-haproxy:6379/0"
REDIS_REQUIRED="1"

REDIS_STORAGE_CLASS="otp-redis-devprod-nfs"
REDIS_SIZE="1Gi"
REDIS_SPREAD_RECREATE_PVCS="auto"

REDIS_NFS_PV_PREFIX="otp-redis-devprod"
REDIS_NFS_SERVER=""
REDIS_NFS_BASE_PATH="/redis"
REDIS_NFS_MOUNT_OPTIONS="nfsvers=4.1"

# ---------------------------------------------------------------------------
# Observability intent packaged/recorded only
# ---------------------------------------------------------------------------
#
# The bundle builder does not run Helm.
# Production-side Helm execution belongs to the approved production procedure.

OBSERVABILITY_NAMESPACE="observability-devprod"
OBSERVABILITY_INSTALL_STACK="1"
OBSERVABILITY_STACK_CHART_VERSION="85.0.1"
GRAFANA_HOST="grafana-devprod.init-db.lan"

# ---------------------------------------------------------------------------
# Bundle-builder behavior
# ---------------------------------------------------------------------------

RUNTIME_DATA_DIR=""
SKIP_HELP_DOCS_BUILD="0"
GIT_CLEAN="1"
SKIP_REPO_SYNC="auto"
NONINTERACTIVE="0"

# Final tarball output directory. Optional.
DIST_DIR="dist"

# ---------------------------------------------------------------------------
# Deprecated live-deployment settings intentionally disabled
# ---------------------------------------------------------------------------

GITHUB_RUNNER_URL=""
GITHUB_RUNNER_TOKEN=""
GITHUB_RUNNER_DIR=""
GITHUB_RUNNER_USER=""

IMAGE_DISTRIBUTION_PORT="18080"
IMAGE_IMPORTER_IMAGE="redis:7-alpine"

# Worker VM provisioning is disabled in bundle-only mode.
BRIDGE_NAME=""
HOST_IFACE=""
HOST_IP_CIDR=""
GATEWAY=""
DNS=""
PREFIX=""
IP_SCAN_PREFIX=""
IP_SCAN_START=""
IP_SCAN_END=""
AUTO_ASSIGN_IPS="0"
WORKER1_IP=""
WORKER2_IP=""
VM_USER=""
VM_PASSWORD=""
VM_RAM_MB=""
VM_VCPUS=""
VM_DISK_GB=""
WORKER1_NAME=""
WORKER2_NAME=""
