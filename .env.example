# Copy to .env, edit once, then run sudo bash install-otp-relay-k8s.sh.
# The installer also creates this file interactively when .env is missing.

REPO_URL="https://github.com/psi1703/k8s-ansible.git"
REPO_REF="main"
INSTALL_DIR="/opt/k8s-ansible"
NAMESPACE="otp-relay"
APP_IMAGE="otp-relay:latest"
MONITOR_IMAGE="otp-monitor:latest"
DEPLOY_MODE="full"

SERVICE_TYPE="ClusterIP"
SERVICE_NODE_PORT="30080"
LOADBALANCER_IP=""
INGRESS_ENABLED="1"
TLS_ENABLED="1"
TLS_HOST="CHANGE_ME_HOSTNAME"
TLS_SECRET_NAME="otp-relay-tls"
TLS_SELF_SIGNED="1"
PORTAL_URL=""

PVC_STORAGE_CLASS=""
PVC_SIZE="1Gi"
NFS_ENABLED="0"
NFS_SERVER=""
NFS_PATH=""
NFS_STORAGE_CLASS="otp-relay-nfs"
NFS_PV_NAME="otp-relay-data-nfs-pv"
NFS_MOUNT_OPTIONS="nfsvers=4.1"

REPLICA_COUNT="2"
APP_NODE_SELECTOR_KEY=""
APP_NODE_SELECTOR_VALUE=""
MONITOR_NODE_SELECTOR_KEY=""
MONITOR_NODE_SELECTOR_VALUE=""
REDIS_NODE_SELECTOR_KEY=""
REDIS_NODE_SELECTOR_VALUE=""

REQUIRE_METALLB="0"
INSTALL_METALLB="0"
METALLB_VERSION="v0.15.3"
METALLB_IP_RANGE=""
METALLB_POOL_NAME="otp-relay-pool"

PHONE_IP="CHANGE_ME_PHONE_IP"
PHONE_INTERFACE="CHANGE_ME_INTERFACE"
PHONE_PING_INTERVAL="150"
PHONE_OFFLINE_THRESHOLD="2"
PHONE_ARP_COUNT="2"
PHONE_ARP_TIMEOUT="2"
MONITOR_METRICS_PORT="9101"
OTP_RELAY_DATA_DIR="/app/data"
USERS_EXCEL_PATH="/app/data/users.xlsx"
AUDIT_LOG_PATH="/app/data/audit.log"
CLAIM_EXPIRY_SEC="90"
OTP_DISPLAY_SEC="285"
CONCURRENT_RISK_SEC="30"

SMS_SECRET_TOKEN="CHANGE_ME_SECRET"
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

REDIS_ENABLED="1"
REDIS_URL="redis://otp-redis-haproxy:6379/0"
REDIS_REQUIRED="1"
REDIS_STORAGE_CLASS="local-path"
REDIS_SIZE="1Gi"
REDIS_SPREAD_RECREATE_PVCS="auto"

RUNTIME_DATA_DIR=""
SKIP_HELP_DOCS_BUILD="0"
GIT_CLEAN="1"
SKIP_REPO_SYNC="auto"
NONINTERACTIVE="0"
INSTALL_GITHUB_RUNNER=""
GITHUB_RUNNER_URL=""
GITHUB_RUNNER_TOKEN=""
GITHUB_RUNNER_DIR="/opt/actions-runner"
GITHUB_RUNNER_USER="actions-runner"
RUNNER_ONLY="0"
DOCKER_BIN=""
DISTRIBUTE_IMAGES_TO_NODES="1"
IMAGE_DISTRIBUTION_PORT="18080"
IMAGE_IMPORTER_IMAGE="redis:7-alpine"

# Optional libvirt POC VM provisioner inputs
HOST_IP_CIDR="CHANGE_ME_HOST_IP_CIDR"
GATEWAY="CHANGE_ME_GATEWAY"
DNS="CHANGE_ME_DNS"
IP_SCAN_PREFIX="CHANGE_ME_IP_PREFIX"
IP_SCAN_START="150"
IP_SCAN_END="199"
