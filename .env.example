# Copy to .env, edit once, then run:
#   ./setup.sh
#
# Current architecture:
#   - This server/real host is the K3s control-plane and Ansible runner.
#   - The provisioner creates only two worker VMs: worker1 and worker2.
#   - NFS is external and is not joined to Kubernetes.
#   - frontend/app.jsx is source; frontend/app.js is generated during deployment.
#
# Do not commit populated .env files.

REPO_URL="https://github.com/psi1703/k8s-ansible.git"
REPO_REF="main"
INSTALL_DIR="/opt/k8s-ansible"
NAMESPACE="otp-relay"

APP_IMAGE="otp-relay:latest"
MONITOR_IMAGE="otp-monitor:latest"
DEPLOY_MODE="full"

# Service / Ingress
# ClusterIP + Ingress is the preferred default for Traefik.
SERVICE_TYPE="ClusterIP"
SERVICE_NODE_PORT="30080"
LOADBALANCER_IP=""
INGRESS_ENABLED="1"
TLS_ENABLED="0"
TLS_HOST="CHANGE_ME_TLS_HOST"
TLS_SECRET_NAME="otp-relay-tls"
TLS_SELF_SIGNED="1"
PORTAL_URL=""

# App storage
# NFS is external. Set NFS_SERVER and NFS_PATH to the real export.
PVC_STORAGE_CLASS="otp-relay-nfs"
PVC_SIZE="1Gi"
NFS_ENABLED="1"
NFS_SERVER="CHANGE_ME_NFS_SERVER"
NFS_PATH="CHANGE_ME_NFS_EXPORT_PATH"
NFS_STORAGE_CLASS="otp-relay-nfs"
NFS_PV_NAME="otp-relay-data-nfs-pv"
NFS_MOUNT_OPTIONS="nfsvers=4.1"

# Replicas / scheduling
# App and Redis should run on worker nodes through node labels.
# Monitor can run on the control-plane/server because it needs host network/ARP access.
REPLICA_COUNT="2"
APP_NODE_SELECTOR_KEY="otp-relay/app-node"
APP_NODE_SELECTOR_VALUE="true"
MONITOR_NODE_SELECTOR_KEY="otp-relay/monitor-node"
MONITOR_NODE_SELECTOR_VALUE="true"
REDIS_NODE_SELECTOR_KEY="otp-relay/redis-node"
REDIS_NODE_SELECTOR_VALUE="true"

# MetalLB
# SERVICE_TYPE=LoadBalancer requires a load balancer.
# ClusterIP + Ingress does not require MetalLB.
REQUIRE_METALLB="0"
INSTALL_METALLB="0"
METALLB_VERSION="v0.15.3"
METALLB_IP_RANGE=""
METALLB_POOL_NAME="otp-relay-pool"

# Monitor / phone presence
PHONE_IP="CHANGE_ME_PHONE_IP"
PHONE_INTERFACE="CHANGE_ME_INTERFACE"
PHONE_PING_INTERVAL="10"
PHONE_OFFLINE_THRESHOLD="30"
PHONE_ARP_COUNT="2"
PHONE_ARP_TIMEOUT="2"
MONITOR_METRICS_PORT="9101"

# Runtime paths
OTP_RELAY_DATA_DIR="/app/data"
USERS_EXCEL_PATH="/app/data/users.xlsx"
AUDIT_LOG_PATH="/app/data/audit.log"
CLAIM_EXPIRY_SEC="90"
OTP_DISPLAY_SEC="285"
CONCURRENT_RISK_SEC="30"

# Secrets
SMS_SECRET_TOKEN="CHANGE_ME_SECRET"
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Redis HA/shared state
REDIS_ENABLED="1"
REDIS_URL="redis://otp-redis-haproxy:6379/0"
REDIS_REQUIRED="1"
REDIS_STORAGE_CLASS="local-path"
REDIS_SIZE="1Gi"
REDIS_SPREAD_RECREATE_PVCS="auto"

# Installer behavior
RUNTIME_DATA_DIR=""
SKIP_HELP_DOCS_BUILD="0"
GIT_CLEAN="1"
SKIP_REPO_SYNC="auto"
NONINTERACTIVE="0"
INSTALL_GITHUB_RUNNER=""
GITHUB_RUNNER_URL=""
GITHUB_RUNNER_TOKEN=""
GITHUB_RUNNER_DIR="/opt/actions-runner"
GITHUB_RUNNER_USER="actions-runner"
RUNNER_ONLY="0"
DOCKER_BIN=""
DISTRIBUTE_IMAGES_TO_NODES="1"
IMAGE_DISTRIBUTION_PORT="18080"
IMAGE_IMPORTER_IMAGE="redis:7-alpine"

# Worker VM provisioner inputs
# No CP_IP exists in this design. The server is the control-plane.
BRIDGE_NAME="br0"
HOST_IFACE="CHANGE_ME_HOST_INTERFACE"
HOST_IP_CIDR="CHANGE_ME_HOST_IP_CIDR"
GATEWAY="CHANGE_ME_GATEWAY"
DNS="CHANGE_ME_DNS"
PREFIX="24"
IP_SCAN_PREFIX="CHANGE_ME_IP_PREFIX"
IP_SCAN_START="150"
IP_SCAN_END="199"
AUTO_ASSIGN_IPS="1"
WORKER1_IP=""
WORKER2_IP=""
VM_USER="otp-relay"
# Required for worker VM provisioning. Change this before running setup.
VM_PASSWORD="CHANGE_ME_VM_PASSWORD"
VM_RAM_MB="3072"
VM_VCPUS="2"
VM_DISK_GB="20"
WORKER1_NAME="otp-worker1"
WORKER2_NAME="otp-worker2"

# Observability
# When enabled, the installer deploys kube-prometheus-stack with Helm, then
# applies OTP Relay dashboard, ServiceMonitor, and Grafana IngressRoute YAMLs.
OBSERVABILITY_NAMESPACE="observability"
OBSERVABILITY_INSTALL_STACK="1"
OBSERVABILITY_STACK_CHART_VERSION="85.0.1"
GRAFANA_HOST="grafana-test.lan"
