# OTP Relay — secret values
# Copy this file to secret.env, fill in the real values, and NEVER commit secret.env to git.
# Apply to the cluster with:
#
#   kubectl create secret generic otp-relay-secrets \
#     --from-env-file=k8s/manifests/secret.env \
#     --namespace=otp-relay \
#     --dry-run=client -o yaml | kubectl apply -f -

SMS_SECRET_TOKEN=replace-with-output-of-python3-secrets-token-hex-32
TELEGRAM_BOT_TOKEN=replace-with-telegram-bot-token
TELEGRAM_CHAT_ID=replace-with-telegram-chat-id
